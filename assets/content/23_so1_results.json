              ]
            ]
          },
          {
            "type": "table",
            "caption": "Statistical Tests — Environmental Robustness",
            "headers": [
              "Test",
              "Statistic",
              "p-value",
              "Interpretation"
            ],
            "rows": [
              [
                "Paired t-test",
                "−3.3411",
