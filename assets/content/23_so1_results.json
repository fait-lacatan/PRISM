                "−32.7683",
                "−24.5254"
              ],
              [
                "t-test p-value",
                "1.6336 × 10⁻²¹³",
                "1.5935 × 10⁻¹²⁵"
              ],
              [
                "Cohen's d",
                "−0.6553",
                "−0.4892"
              ],
              [
                "Effect Size",
                "Medium",
                "Small"
              ]
            ]
          },
          {
            "type": "prose",
            "text": "Environmental robustness was evaluated by comparing 10 subjects under controlled conditions (consistent lighting, neutral expression) versus uncontrolled conditions (variable lighting and expression). The question is whether real-world deployment conditions degrade the model enough to reject genuine users."
          },
          {
            "type": "table",
            "caption": "Environmental Robustness Comparison",
            "headers": [
              "Scenario",
              "Mean Distance",
              "Std Dev",
              "FNMR (%)"
            ],
            "rows": [
              [
                "Controlled",
                "0.0004",
                "0.0004",
                "0.00"
              ],
              [
